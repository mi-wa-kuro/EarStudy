<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md bg-white rounded-2xl shadow-md p-8">
    <h2 class="text-2xl font-bold text-center text-gray-800 mb-2">
      新規登録
    </h2>

    <p class="text-center text-gray-500 mb-8">
      EarStudyをはじめましょう
    </p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-800 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none" %>
      </div>

      <div>
        <%= f.label :password, "パスワード", class: "block text-sm font-medium text-gray-700 mb-2" %>

        <% if @minimum_password_length %>
          <p class="text-xs text-gray-500 mb-2">
            <%= @minimum_password_length %>文字以上で入力してください
          </p>
        <% end %>

        <%= f.password_field :password,
              autocomplete: "new-password",
              class: "w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-800 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "パスワード確認", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-800 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none" %>
      </div>

      <div>
        <%= f.submit "登録する",
              class: "w-full rounded-lg bg-blue-600 px-4 py-3 text-white font-semibold hover:bg-blue-700 transition cursor-pointer" %>
      </div>
    <% end %>

    <div class="mt-6 text-center text-sm text-gray-600">
      <p>
        すでにアカウントをお持ちの方は
        <%= link_to "ログイン", new_user_session_path, class: "text-blue-600 font-semibold hover:underline" %>
      </p>
    </div>
  </div>
</div>