<h1>学習ノート編集</h1>

<%= form_with model: @note, local: true do |f| %>
  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :content, "内容" %><br>
    <%= f.text_area :content %>
  </div>

  <%= f.submit "更新する" %>
<% end %>

<%= link_to "一覧に戻る", notes_path %>