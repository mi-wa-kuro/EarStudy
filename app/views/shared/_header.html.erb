<header class="header">
  <%= link_to root_path, class: 'header__logo' do %>
    <%= image_tag 'EarStudyLogo.png', alt: 'EarStudy' %>
  <% end %>

  <div class="header__actions">
  <% if user_signed_in? %>
    <%= link_to '学習ノート一覧', '#', class: 'header__link' %>
    <%= link_to 'ログアウト', destroy_user_session_path, data: { turbo_method: :delete }, class: 'header__login-btn' %>
  <% else %>
    <%= link_to 'ログイン', new_user_session_path, class: 'header__login-btn' %>
    <%= link_to '新規登録', new_user_registration_path, class: 'header__signup-btn' %>
  <% end %>
</header>